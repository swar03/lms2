// LMS Prisma Schema File
// Production-ready schema for cybersecurity-focused LMS platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  STUDENT
  EDUCATOR
  ADMIN
}

enum CourseType {
  PAID_TRAINING
  FREE_TRAINING_INTERNSHIP
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum CertificateStatus {
  PENDING
  GENERATED
  VERIFIED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

// User model (supports both Google OAuth and Manual login)
model User {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String   @db.VarChar(100)
  email          String   @unique @db.VarChar(255)
  password       String?  // For manual sign-up
  role           UserRole @default(STUDENT)
  countryCode    String?  // For manual sign-up
  phoneNumber    String?  // For manual sign-up

  // Google OAuth specific fields
  googleId       String?  @unique @map("google_id") @db.VarChar(100)
  profilePicture String?  @map("profile_picture")

  // Common fields
  isActive       Boolean  @default(true) @map("is_active")
  surveyCompleted Boolean  @default(false) @map("survey_completed")
  lastLogin      DateTime? @map("last_login") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships (no changes here)
  surveyResponses       SurveyResponse[]
  coursesAsInstructor   Course[]               @relation("CourseInstructor")
  courseEnrollments     CourseEnrollment[]
  studentProgress       StudentProgress[]
  studentStreak         StudentStreak?
  dailyActivities       DailyActivity[]
  quizAttempts          QuizAttempt[]
  assignmentSubmissions AssignmentSubmission[]
  orders                Order[]
  payments              Payment[]
  shoppingCart          ShoppingCart[]
  wishlists             Wishlist[]
  certificates          Certificate[]
  studentAnalytics      StudentAnalytics?
  assignmentReviews     AssignmentSubmission[] @relation("AdminReviewer")

  @@map("users")
}

// Survey Questions model
model SurveyQuestion {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  questionText String   @map("question_text")
  questionType String   @map("question_type") @db.VarChar(50)
  options      Json?    @db.JsonB
  isRequired   Boolean  @default(true) @map("is_required")
  displayOrder Int      @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  responses SurveyResponse[]

  @@map("survey_questions")
}

// Survey Responses model
model SurveyResponse {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  questionId   String   @map("question_id") @db.Uuid
  responseText String?  @map("response_text")
  responseData Json?    @map("response_data") @db.JsonB
  submittedAt  DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  // Relationships
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("survey_responses")
}

// Course Categories model
model CourseCategory {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String   @unique @db.VarChar(100)
  description  String?
  iconUrl      String?  @map("icon_url")
  displayOrder Int?     @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  courses Course[]

  @@map("course_categories")
}

// Courses model
model Course {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title            String          @db.VarChar(255)
  description      String
  shortDescription String?         @map("short_description")
  instructorId     String          @map("instructor_id") @db.Uuid
  categoryId       String?         @map("category_id") @db.Uuid
  courseType       CourseType      @map("course_type")
  price            Decimal         @default(0.00) @db.Decimal(10, 2)
  currency         String          @default("INR") @db.VarChar(3)
  difficultyLevel  DifficultyLevel @map("difficulty_level")
  durationWeeks    Int?            @map("duration_weeks")
  totalLessons     Int             @default(0) @map("total_lessons")
  totalLabs        Int             @default(0) @map("total_labs")
  totalProjects    Int             @default(0) @map("total_projects")
  thumbnailUrl     String?         @map("thumbnail_url")
  previewVideoUrl  String?         @map("preview_video_url")
  isPublished      Boolean         @default(false) @map("is_published")
  placementRate    Decimal?        @map("placement_rate") @db.Decimal(5, 2)
  averageSalary    Decimal?        @map("average_salary") @db.Decimal(12, 2)
  totalGraduates   Int             @default(0) @map("total_graduates")
  partnerCompanies Int             @default(0) @map("partner_companies")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  instructor      User               @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  category        CourseCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  modules         CourseModule[]
  enrollments     CourseEnrollment[]
  payments        Payment[]
  shoppingCart    ShoppingCart[]
  wishlists       Wishlist[]
  certificates    Certificate[]
  courseAnalytics CourseAnalytics?

  @@map("courses")
}

// Course Modules model
model CourseModule {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  courseId        String          @map("course_id") @db.Uuid
  title           String          @db.VarChar(255)
  description     String?
  moduleOrder     Int             @map("module_order")
  durationWeeks   Int?            @map("duration_weeks")
  difficultyLevel DifficultyLevel @map("difficulty_level")
  totalLabs       Int             @default(0) @map("total_labs")
  totalProjects   Int             @default(0) @map("total_projects")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  assignments  Assignment[]
  certificates Certificate[]

  @@unique([courseId, moduleOrder])
  @@map("course_modules")
}

// Lessons model
model Lesson {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moduleId          String    @map("module_id") @db.Uuid
  title             String    @db.VarChar(255)
  description       String?
  lessonOrder       Int       @map("lesson_order")
  videoUrl          String?   @map("video_url")
  durationMinutes   Int?      @map("duration_minutes")
  contentMarkdown   String?   @map("content_markdown")
  resources         Json?     @db.JsonB
  isPreview         Boolean   @default(false) @map("is_preview")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  module          CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  studentProgress StudentProgress[]
  quizQuestions   QuizQuestion[]
  quizAttempts    QuizAttempt[]

  @@unique([moduleId, lessonOrder])
  @@map("lessons")
}

// Course Enrollments model
model CourseEnrollment {
  id                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId            String           @map("student_id") @db.Uuid
  courseId             String           @map("course_id") @db.Uuid
  enrollmentDate       DateTime         @default(now()) @map("enrollment_date") @db.Timestamptz(6)
  completionDate       DateTime?        @map("completion_date") @db.Timestamptz(6)
  status               EnrollmentStatus @default(ACTIVE)
  progressPercentage   Decimal          @default(0.00) @map("progress_percentage") @db.Decimal(5, 2)
  timeSpentMinutes     Int              @default(0) @map("time_spent_minutes")
  lastAccessed         DateTime?        @map("last_accessed") @db.Timestamptz(6)
  certificateIssued    Boolean          @default(false) @map("certificate_issued")
  certificateId        String?          @map("certificate_id") @db.Uuid

  // Relationships
  student               User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentProgress       StudentProgress[]
  quizAttempts          QuizAttempt[]
  assignmentSubmissions AssignmentSubmission[]

  @@unique([studentId, courseId])
  @@map("course_enrollments")
}

// Student Progress model
model StudentProgress {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  enrollmentId        String           @map("enrollment_id") @db.Uuid
  lessonId            String           @map("lesson_id") @db.Uuid
  isCompleted         Boolean          @default(false) @map("is_completed")
  completionDate      DateTime?        @map("completion_date") @db.Timestamptz(6)
  timeSpentMinutes    Int              @default(0) @map("time_spent_minutes")
  lastWatchedPosition Int              @default(0) @map("last_watched_position")
  watchCount          Int              @default(0) @map("watch_count")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [studentId], references: [id])
  studentId  String           @map("student_id") @db.Uuid


  @@unique([enrollmentId, lessonId])
  @@map("student_progress")
}

// Student Streaks model
model StudentStreak {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId        String    @unique @map("student_id") @db.Uuid
  currentStreak    Int       @default(0) @map("current_streak")
  longestStreak    Int       @default(0) @map("longest_streak")
  lastActivityDate DateTime? @map("last_activity_date") @db.Date
  totalDaysActive  Int       @default(0) @map("total_days_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_streaks")
}

// Daily Activities model
model DailyActivity {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId            String   @map("student_id") @db.Uuid
  activityDate         DateTime @map("activity_date") @db.Date
  timeSpentMinutes     Int      @default(0) @map("time_spent_minutes")
  lessonsCompleted     Int      @default(0) @map("lessons_completed")
  quizzesAttempted     Int      @default(0) @map("quizzes_attempted")
  assignmentsSubmitted Int      @default(0) @map("assignments_submitted")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relationships
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, activityDate])
  @@map("daily_activities")
}

// Quiz Questions model
model QuizQuestion {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lessonId      String          @map("lesson_id") @db.Uuid
  questionText  String          @map("question_text")
  questionType  String          @map("question_type") @db.VarChar(50)
  options       Json?           @db.JsonB
  correctAnswer String?         @map("correct_answer")
  explanation   String?
  points        Int             @default(1)
  difficulty    DifficultyLevel @default(BEGINNER)
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

// Quiz Attempts model
model QuizAttempt {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId        String    @map("student_id") @db.Uuid
  lessonId         String    @map("lesson_id") @db.Uuid
  enrollmentId     String    @map("enrollment_id") @db.Uuid
  attemptNumber    Int       @map("attempt_number")
  totalQuestions   Int       @map("total_questions")
  correctAnswers   Int       @default(0) @map("correct_answers")
  score            Decimal   @default(0.00) @db.Decimal(5, 2)
  timeTakenMinutes Int?      @map("time_taken_minutes")
  isCompleted      Boolean   @default(false) @map("is_completed")
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  answers          Json?     @db.JsonB

  // Relationships
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId, attemptNumber])
  @@map("quiz_attempts")
}

// Assignments model
model Assignment {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moduleId         String    @map("module_id") @db.Uuid
  title            String    @db.VarChar(255)
  description      String
  instructions     String?
  requirements     Json?     @db.JsonB
  dueDate          DateTime? @map("due_date") @db.Timestamptz(6)
  maxPoints        Int       @default(100) @map("max_points")
  submissionFormat String?   @map("submission_format") @db.VarChar(100)
  isMandatory      Boolean   @default(true) @map("is_mandatory")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  module      CourseModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@map("assignments")
}

// Assignment Submissions model
model AssignmentSubmission {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  assignmentId    String           @map("assignment_id") @db.Uuid
  studentId       String           @map("student_id") @db.Uuid
  enrollmentId    String           @map("enrollment_id") @db.Uuid
  submissionText  String?          @map("submission_text")
  fileUrls        Json?            @map("file_urls") @db.JsonB
  screenshotUrls  Json?            @map("screenshot_urls") @db.JsonB
  submittedAt     DateTime         @default(now()) @map("submitted_at") @db.Timestamptz(6)
  status          AssignmentStatus @default(SUBMITTED)
  adminFeedback   String?          @map("admin_feedback")
  adminId         String?          @map("admin_id") @db.Uuid
  reviewedAt      DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  pointsAwarded   Int?             @map("points_awarded")

  // Relationships
  assignment Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  admin      User?            @relation("AdminReviewer", fields: [adminId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// Orders model
model Order {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId       String        @map("student_id") @db.Uuid
  razorpayOrderId String        @unique @map("razorpay_order_id") @db.VarChar(100)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR") @db.VarChar(3)
  status          PaymentStatus @default(PENDING)
  notes           Json?         @db.JsonB
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  student  User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("orders")
}

// Payments model
model Payment {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId           String        @map("order_id") @db.Uuid
  studentId         String        @map("student_id") @db.Uuid
  courseId          String        @map("course_id") @db.Uuid
  razorpayPaymentId String?       @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?       @map("razorpay_signature")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR") @db.VarChar(3)
  status            PaymentStatus @default(PENDING)
  paymentMethod     String?       @map("payment_method") @db.VarChar(50)
  processedAt       DateTime?     @map("processed_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relationships
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// Shopping Cart model
model ShoppingCart {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  // Relationships
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@map("shopping_cart")
}

// Wishlist model
model Wishlist {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  // Relationships
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@map("wishlists")
}

// Certificate Templates model
model CertificateTemplate {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String      @db.VarChar(100)
  courseType   CourseType  @map("course_type")
  templateHtml String      @map("template_html")
  templateCss  String?     @map("template_css")
  fields       Json        @db.JsonB
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  certificates Certificate[]

  @@map("certificate_templates")
}

// Certificates model
model Certificate {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  certificateNumber String            @unique @map("certificate_number") @db.VarChar(50)
  studentId         String            @map("student_id") @db.Uuid
  courseId          String?           @map("course_id") @db.Uuid
  moduleId          String?           @map("module_id") @db.Uuid
  templateId        String            @map("template_id") @db.Uuid
  certificateData   Json              @map("certificate_data") @db.JsonB
  pdfUrl            String?           @map("pdf_url")
  verificationUrl   String?           @map("verification_url")
  status            CertificateStatus @default(PENDING)
  issuedDate        DateTime          @default(now()) @map("issued_date") @db.Timestamptz(6)
  expiresAt         DateTime?         @map("expires_at") @db.Timestamptz(6)
  isShareable       Boolean           @default(true) @map("is_shareable")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relationships
  student  User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course   Course?             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module   CourseModule?       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  template CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// Course Analytics model
model CourseAnalytics {
  id               String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  courseId         String  @unique @map("course_id") @db.Uuid
  totalEnrollments Int     @default(0) @map("total_enrollments")
  activeStudents   Int     @default(0) @map("active_students")
  completionRate   Decimal @default(0.00) @map("completion_rate") @db.Decimal(5, 2)
  averageRating    Decimal @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalRevenue     Decimal @default(0.00) @map("total_revenue") @db.Decimal(12, 2)
  lastCalculated   DateTime @default(now()) @map("last_calculated") @db.Timestamptz(6)

  // Relationships
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_analytics")
}

// Student Analytics model
model StudentAnalytics {
  id                      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId               String   @unique @map("student_id") @db.Uuid
  totalCoursesEnrolled    Int      @default(0) @map("total_courses_enrolled")
  totalCoursesCompleted   Int      @default(0) @map("total_courses_completed")
  totalTimeSpentMinutes   Int      @default(0) @map("total_time_spent_minutes")
  totalCertificatesEarned Int      @default(0) @map("total_certificates_earned")
  currentStreak           Int      @default(0) @map("current_streak")
  longestStreak           Int      @default(0) @map("longest_streak")
  lastCalculated          DateTime @default(now()) @map("last_calculated") @db.Timestamptz(6)

  // Relationships
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_analytics")
}